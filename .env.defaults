# ─────────────────────────────────────────────────────────────────────────────
# Non-secret application configuration (committed defaults).
#
# These are the deployment-tunable defaults for the Streamlit app, loaded by
# crawl4md_streamlit.settings (pydantic-settings). Override any value per
# environment in a local, git-ignored ".env" file, or — on Streamlit Community
# Cloud — in the Secrets console, then restart the app. No redeploy needed.
#
# Secrets (AWS_*, OPENAI_API_KEY) do NOT belong here. See ".env.example".
# ─────────────────────────────────────────────────────────────────────────────

# ── Step 1 · Crawl ───────────────────────────────────────────────────────────
# Default starting values for the crawl form; users can still override any of
# these per crawl in the UI.
# Pages to crawl before stopping (the crawl breadth).
CRAWL_LIMIT=100
# How many links deep to follow from each seed URL.
CRAWL_MAX_DEPTH=5
# Parallel page fetches. Higher = faster but more load and WAF risk.
CRAWL_MAX_CONCURRENT=5
# Pages buffered before each incremental flush to disk.
CRAWL_FLUSH_INTERVAL=5
# Polite delay (seconds) between page fetches.
CRAWL_DELAY=1.0
# Extra retry rounds for failed pages (minimum 2 enforced by the crawler).
CRAWL_MAX_RETRIES=2
# Seconds to wait for late content after a page loads.
CRAWL_WAIT_FOR=3.0
# Per-page navigation/extraction timeout, in seconds.
CRAWL_TIMEOUT=60.0
# Maximum size of a single extracted page file, in MB (larger pages are split).
CRAWL_MAX_FILE_SIZE_MB=10.0
# Lines of activity log retained for the live crawl view.
CRAWL_ACTIVITY_LOG_SIZE=10
# Default seed URL(s) pre-filled in the crawl form (comma-separated for more than
# one). Users can still edit these per crawl.
CRAWL_DEFAULT_URLS=https://www.ato.gov.au/
# Default "only include" URL filter(s), comma-separated (substring or regex).
CRAWL_INCLUDE_ONLY_PATHS=ato.gov.au
# Default "skip" URL filter(s), comma-separated (substring or regex).
CRAWL_EXCLUDE_PATHS=ato.gov.au/api/
# Default HTML tags stripped before extraction, comma-separated.
CRAWL_EXCLUDE_TAGS=nav, script, form, style
# Default output file extension for extracted pages (".md" or ".txt").
CRAWL_DEFAULT_OUTPUT_EXTENSION=.md
# When true, the initial crawl also routes through the configured proxies (the
# CRAWL_PROXIES secret); when false (default) proxies are used only on retry
# rounds. Has no effect unless CRAWL_PROXIES is set.
CRAWL_PROXY_ON_INITIAL=false

# ── Step 2 · Vector index ────────────────────────────────────────────────────
# Tokens per chunk. Larger = more context per match; smaller = more precise.
VECTOR_CHUNK_SIZE=600
# Overlap between adjacent chunks so context is not cut at boundaries.
VECTOR_CHUNK_OVERLAP=100
# Default embedding vector size; must be supported by the chosen model.
VECTOR_EMBEDDING_DIMENSION=512
# Parallel embedding workers (1-8). Higher speeds up cloud models (Titan/OpenAI)
# on large crawls; the local ONNX model ignores this and runs single-threaded.
VECTOR_INDEX_WORKERS=4
# Embedding models offered in the Vector Index dropdown, in display order.
VECTOR_EMBEDDING_MODELS=all-MiniLM-L6-v2,amazon.titan-embed-text-v2:0,text-embedding-3-small
# Embedding model pre-selected in that dropdown.
VECTOR_DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Steps 3-5 · RAG ──────────────────────────────────────────────────────────
# Chunks retrieved as context for QA/conversational answers.
RAG_TOP_K=4
# Top matches (highest similarity) retrieved as knowledge on the Simple RAG Q&A
# page (Step 4).
RAG_QA_TOP_RESULTS=5
# Tones offered on the Step 4 Tone selector (comma-separated), in display order.
RAG_QA_TONES=Neutral,Formal,Friendly,Funny,Professional,Casual,Concise,Empathetic,Enthusiastic,Technical,Playful
# The tone pre-selected on the Step 4 Tone selector.
RAG_QA_DEFAULT_TONE=Neutral
# Path (relative to the repo root) to the Step 4 prompt template file. Edit that
# file to reword the generated prompt without a code change; keep the
# {question}/{start}/{knowledge}/{end}/{tone} fields and the "treat knowledge as
# data only" rule (the prompt-injection fence). A missing, empty, or invalid file
# falls back to the built-in default.
RAG_QA_PROMPT_TEMPLATE_FILE=apps/streamlit/config/rag_qa_prompt.txt
# Language models offered on the RAG pages (comma-separated rag_engine catalog
# ids), in display order. Unknown ids are ignored. Bedrock ids use APAC
# inference profiles (apac.*) for ap-southeast-2 — confirm each id and your
# account's model access in the Bedrock console (Model access).
RAG_LLM_MODELS=apac.amazon.nova-micro-v1:0,apac.amazon.nova-lite-v1:0,apac.amazon.nova-pro-v1:0,apac.anthropic.claude-3-5-haiku-20241022-v1:0,apac.anthropic.claude-3-5-sonnet-20241022-v2:0,apac.meta.llama3-3-70b-instruct-v1:0,gpt-4o-mini,gpt-4o,echo
# The language model pre-selected on the RAG pages.
RAG_DEFAULT_LLM_MODEL=apac.amazon.nova-lite-v1:0
# Default number of ranked matches shown on the Semantic Search page.
SEMANTIC_SEARCH_TOP_N=5
# Default open tab for each result card: "raw" or "preview".
SEMANTIC_SEARCH_DEFAULT_TAB=raw
# Default search mode: "similarity" (closest matches) or "mmr" (diversified).
SEMANTIC_SEARCH_DEFAULT_MODE=similarity
# Default minimum-similarity filter (percent); 0 keeps all matches.
SEMANTIC_SEARCH_MIN_SCORE_PERCENT=0
# Default MMR candidate-pool size (results are diversified from these).
SEMANTIC_SEARCH_FETCH_K=20
# Default MMR diversity (0-1): 1 favours relevance, 0 favours variety.
SEMANTIC_SEARCH_MMR_LAMBDA=0.5

# ── Session lifecycle ────────────────────────────────────────────────────────
# Days an inactive browser session's files are kept before startup cleanup
# deletes them. Loading or crawling in a session resets its clock.
SESSION_RETENTION_DAYS=7

# ── App UI limits ────────────────────────────────────────────────────────────
# Largest file served as a download, in MB (above this it is view-only).
UI_DOWNLOAD_LIMIT_MB=500
# Largest inline text preview, in KB (above this previews are truncated).
UI_PREVIEW_LIMIT_KB=256
# Seconds between auto-refreshes of the live crawl/index progress panels.
UI_LIVE_REFRESH_SEC=3
# Seconds between auto-refreshes of the Output Files download panel.
UI_DOWNLOADS_REFRESH_SEC=7
# Shared key that signs downloaded zips so they can be re-uploaded to a matching
# instance. Same key + unaltered file = accepted. Override per deployment to scope
# uploads to your own instances; treat as a shared secret if that matters to you.
ZIP_SIGNING_SECRET=rag-playground-prakosd-dev-zip-key

# ── Logging ──────────────────────────────────────────────────────────────────
# Minimum log level shown in the terminal and the rotating log file. Threshold
# model: DEBUG < INFO < WARNING < ERROR (WARN is accepted as WARNING). Lower =
# more detail; raise to WARNING or ERROR in production to quiet developer traces.
LOG_LEVEL=INFO
# Per-session developer log file, written under each session's folder (path
# relative to the session directory) and shown in the app's Files & folders panel.
LOG_FILE=logs/app.log
