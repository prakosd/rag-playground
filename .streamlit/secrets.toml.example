# Streamlit Community Cloud secrets (TOML).
#
# Copy the contents below into your app's Secrets console
# (Manage app → Settings → Secrets), filling in real values. Root-level keys are
# automatically exposed to your app as environment variables, so the libraries'
# AWS/OpenAI SDK calls pick them up with no code change.
#
# Changes take ~1 minute to propagate. Do NOT commit a real
# ".streamlit/secrets.toml" — it is git-ignored.

# ── Secrets: cloud providers (Steps 2-5) ─────────────────────────────────────
# Leave blank to run with the offline default embedding + echo chat model.
AWS_ACCESS_KEY_ID = ""
AWS_SECRET_ACCESS_KEY = ""
AWS_REGION = "us-east-1"
OPENAI_API_KEY = ""
# ── Optional anti-bot escalation for Step 1 crawling (all optional) ──────────
# Comma-separated proxy URLs tried in order (direct first). Used ONLY on retry
# rounds (not the initial crawl) to save cost. Residential proxies are usually
# needed for hard 403s (e.g. Akamai).
CRAWL_PROXIES = ""
# Last-resort scraping API used only when every browser + proxy attempt is blocked;
# the crawler GETs it with ?url=<page>. URL = a hosted scraper's fetch endpoint
# (ScraperAPI/ScrapingBee/ZenRows/Bright Data); TOKEN = optional Bearer key.
CRAWL_FALLBACK_API_URL = ""
CRAWL_FALLBACK_API_TOKEN = ""
# ── Optional non-secret overrides (defaults in .env.defaults) ────────────────
# Uncomment to change a default for the deployed app:
# RAG_TOP_K = "6"
# VECTOR_CHUNK_SIZE = "800"
