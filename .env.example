# Credentials for the optional cloud embedding providers used in
# Step 2 – Build Vector Index. Leave every value blank to use the offline
# default embedding model, which needs no credentials.
#
# These are read from the process environment. In GitHub Codespaces or CI,
# set them as environment secrets/variables instead of committing real values.
# For local use, copy this file to ".env" (which is git-ignored); the Streamlit
# app loads the repo-root ".env" automatically on startup via python-dotenv.

# Amazon Bedrock — Titan embeddings (amazon.titan-embed-text-v2:0, the default model)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# OpenAI — text-embedding-3-small
OPENAI_API_KEY=
