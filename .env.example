# ─────────────────────────────────────────────────────────────────────────────
# Local environment file — copy this to ".env" (git-ignored).
#
# ".env" holds SECRETS and any per-machine overrides. Non-secret configuration
# defaults live in the committed ".env.defaults" and are documented there; copy
# any of those keys here to override them locally.
#
# In Codespaces/CI these come from the real environment instead, so a missing
# package or file is not an error. On Streamlit Community Cloud, paste secrets
# into the Secrets console (see ".streamlit/secrets.toml.example").
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets: optional cloud embedding/chat providers (Steps 2-5) ─────────────
# Leave every value blank to use the offline default embedding + echo chat
# model, which needs no credentials.

# Amazon Bedrock — Titan embeddings (amazon.titan-embed-text-v2:0) + Claude/Nova chat
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# OpenAI — embeddings + chat
OPENAI_API_KEY=

# ── Optional non-secret overrides (defaults live in .env.defaults) ───────────
# Uncomment to override a default on this machine, e.g.:
# RAG_TOP_K=6
# VECTOR_CHUNK_SIZE=800
